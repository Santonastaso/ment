# Supabase Management API token (rotate at https://supabase.com/dashboard/account/tokens)
SUPABASE_PAT=

# Project identifiers (printed when you create a Supabase project)
SUPABASE_PROJECT_REF=
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — set as Edge Function secrets via:
#   supabase secrets set ANTHROPIC_API_KEY=...
ANTHROPIC_API_KEY=
