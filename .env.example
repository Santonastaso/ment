# Required — generate with: openssl rand -hex 32
JWT_SECRET=

# Optional — improves profile import and reflection classification
ANTHROPIC_API_KEY=

# SQLite file path (Docker: mount /data and set DB_PATH=/data/ment.db)
DB_PATH=./ment.db

# Comma-separated browser origins for CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

PORT=3001
