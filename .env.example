# Supabase access token for CLI / GitHub Actions
# Rotate at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# Project identifiers and connection info
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=
SUPABASE_URL=https://YOUR_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional AI classification. Defaults off; enable only after privacy/legal review.
#   supabase secrets set AI_CLASSIFICATION_ENABLED=true ANTHROPIC_API_KEY=...
AI_CLASSIFICATION_ENABLED=false
ANTHROPIC_API_KEY=
