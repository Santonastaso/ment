# Dependencies (reinstalled via `npm install`)
node_modules/
**/node_modules/

# Build output (regenerated by `npm run build`)
client/dist/
client/.vite/

# Migration scratch files
migration-id-map.json
migration-id-map.*.json

# Supabase CLI cache
supabase/.temp/
supabase/.branches/

# Vercel local project metadata
.vercel/

# Environment variables — keep secrets out of git
.env
.env.local
.env.*.local

# Logs
*.log
/tmp/*.log

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# Local archives (we'll keep the source files, not the bundles)
*.tar.gz
*.zip

# Test scratchpad
/tmp/test-*.js

# Python bytecode (from scripts/*.py dev tooling)
__pycache__/
*.pyc
