# Dependencies (reinstalled via `npm install`)
node_modules/
**/node_modules/

# Build output (regenerated by `npm run build`)
client/dist/
client/.vite/

# SQLite database (regenerated by `npm run seed` / `npm run seed:large`)
server/ment.db
server/ment.db-shm
server/ment.db-wal

# Environment variables — keep secrets out of git
.env
.env.local
.env.*.local

# Logs
*.log
/tmp/*.log

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/settings.json

# Local archives (we'll keep the source files, not the bundles)
*.tar.gz
*.zip

# Test scratchpad
/tmp/test-*.js
